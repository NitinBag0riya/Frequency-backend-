# ═══════════════════════════════════════════════════════════════════════════
# Frequency server — environment variable reference.
#
# Copy to `.env` and fill in. Local dev can leave most things blank — code
# degrades gracefully:
#   - send_email   → falls back from Gmail to Resend if Gmail not connected
#   - AI features  → skip with a clear message if ANTHROPIC_API_KEY missing
#   - Billing      → 503s the checkout route if Razorpay keys missing
#   - Connectors   → ❌"X not connected" on first workflow node that needs it
#
# Production REQUIRED set (boot-time check):
#   IMPERSONATION_HMAC_SECRET — server exits 1 if missing in NODE_ENV=production
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
# Trusted proxy hops (1 if behind one CDN/load-balancer, 0 for direct).
TRUST_PROXY_HOPS=1
# Public origin of THIS API server. Used by every connector OAuth callback
# URL builder. Must be HTTPS in production.
PUBLIC_API_URL=http://localhost:3001

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Settings → API → service_role key (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token from supabase.com/dashboard/account/tokens
# (used by scripts/flush-and-seed.mjs and Claude Code MCP, not the runtime)
SUPABASE_ACCESS_TOKEN=

# ── Production safety: BLOCKER if missing in prod ──────────────────────────
# 32-byte hex used to HMAC-sign super-admin impersonation tokens.
# Generate with: openssl rand -hex 32
# Server boot-checks this in NODE_ENV=production and process.exit(1) if unset.
IMPERSONATION_HMAC_SECRET=

# ── AI (Anthropic / Frequency AI) ──────────────────────────────────────────
# Required for: /api/parse-workflow, /api/skills/match, run_ai_responder
# node, workflow recommendations, AI token accounting in usage_counters.
ANTHROPIC_API_KEY=
# Set to 1 to log every AI call's token usage to stdout.
LOG_AI_USAGE=0

# ── Meta (WhatsApp Business + Instagram) ───────────────────────────────────
# From developers.facebook.com → Your App
META_APP_ID=
META_APP_SECRET=
# Webhook verify token — paste the same string in Meta App Dashboard
# webhook config. Same value used for both WhatsApp and Instagram.
WH_VERIFY_TOKEN=Frequency_webhook_secret
META_VERIFY_TOKEN=Frequency_webhook_secret
# Optional explicit Instagram OAuth callback. Defaults to
# ${PUBLIC_API_URL}/api/auth/instagram/callback.
META_REDIRECT_URI=

# ── Google (OAuth + Sheets/Calendar/Drive/Gmail) ──────────────────────────
# From console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# 32-char hex — AES-encrypts stored Google refresh tokens.
# Generate with: openssl rand -hex 16
GOOGLE_TOKEN_SECRET=

# ── Razorpay (REQUIRED for billing + workflow `payment` node) ─────────────
# Razorpay Dashboard → Settings → API Keys (use rzp_test_* in dev)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay Dashboard → Webhooks → Active Webhook → Webhook Secret
# Used to HMAC-verify subscription.activated / payment.captured events.
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Partner OAuth (OPTIONAL — only if approved as Partner.
# API-key paste flow above works today without these.)
RAZORPAY_PARTNER_CLIENT_ID=
RAZORPAY_PARTNER_CLIENT_SECRET=
RAZORPAY_PARTNER_REDIRECT_URI=http://localhost:3001/api/auth/razorpay/callback

# ── Resend (REQUIRED unless every tenant uses Gmail) ──────────────────────
# Email path: tenant Gmail (preferred) → Resend (fallback). System
# notifications (trial-ending, billing alerts) ALWAYS use Resend.
# Resend Dashboard → API Keys (re_…)
RESEND_API_KEY=
# Format: "Frequency <hello@frequency.in>" or just "hello@frequency.in"
RESEND_FROM_EMAIL=
# Optional Reply-To header (defaults to no Reply-To)
RESEND_REPLY_TO=

# ── WhatsApp notification template ────────────────────────────────────────
# Pre-approved Meta template name on the tenant's WABA. Body must be
# `*{{1}}*\n{{2}}` — title bold, body underneath. Defaults to
# 'frequency_notification'; that template must be submitted + approved
# per WABA OR overridden here per tenant.
WA_NOTIFICATION_TEMPLATE_NAME=frequency_notification
WA_NOTIFICATION_TEMPLATE_LANG=en

# ── Connectors (per-app OAuth — OPTIONAL, only if used) ───────────────────
# Airtable — self-serve at https://airtable.com/create/oauth (no approval queue)
AIRTABLE_CLIENT_ID=
AIRTABLE_REDIRECT_URI=http://localhost:3001/api/auth/airtable/callback

# Shopify — Partner app at https://partners.shopify.com/. Custom-app token
# paste flow works without these.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3001/api/auth/shopify/callback
# Shopify API version pin. Code default: '2024-01'.
SHOPIFY_API_VERSION=

# Slack — no OAuth needed. Webhook URL is pasted per-tenant via the
# AppsModal SlackWebhookForm and stored encrypted in tenant_integrations.

# ── Execution engine (BullMQ + Redis) ─────────────────────────────────────
# Local dev: 127.0.0.1; production: Upstash rediss://default:pwd@host:port
REDIS_URL=redis://127.0.0.1:6379
WORKFLOW_CONCURRENCY=10
MESSAGE_CONCURRENCY=5
BROADCAST_CONCURRENCY=3
SCHEDULE_POLL_MS=30000
TEMPLATE_SYNC_INTERVAL_MS=900000
# Gmail polling tick (default 2 min). Lower latency = more quota usage.
GMAIL_POLL_INTERVAL_MS=120000
# Trial-ending notification cadence (default 6h)
TRIAL_ENDING_INTERVAL_MS=21600000
# Set to 1 in the API process if you run a separate worker process,
# or set to 1 in the worker process to skip starting it.
# DISABLE_WORKERS=0

# ── Redis — alternative shape (use either REDIS_URL above OR these) ───────
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=0
