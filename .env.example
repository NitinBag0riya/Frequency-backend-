PORT=3001
FRONTEND_URL=http://localhost:5173

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ACCESS_TOKEN=your_access_token

# Meta / WhatsApp Business
META_APP_ID=
META_APP_SECRET=
WH_VERIFY_TOKEN=Frequency_webhook_secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# 32-char random hex used to AES-encrypt Google refresh tokens at rest.
# Generate with: openssl rand -hex 16
GOOGLE_TOKEN_SECRET=

# ── Execution engine (Phase 1 + 2) ─────────────────────────────────────────
# Local dev: 127.0.0.1; production: Upstash rediss://default:pwd@host:port
REDIS_URL=redis://127.0.0.1:6379
WORKFLOW_CONCURRENCY=10
MESSAGE_CONCURRENCY=5
BROADCAST_CONCURRENCY=3
SCHEDULE_POLL_MS=30000
TEMPLATE_SYNC_INTERVAL_MS=900000
# DISABLE_WORKERS=0
