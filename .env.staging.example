# ═══════════════════════════════════════════════════════════════════════════
# Frequency server — STAGING environment template.
#
# Use this as a starting point when configuring environment variables in
# your staging deployment platform (Railway / Fly.io / Render / etc.).
# Local dev should use `.env.example` instead — values here assume a real
# Supabase staging project + sandbox keys for every external provider.
#
# Never commit the resolved file. This template is committed; the resolved
# secrets live in the deploy platform's secret manager.
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=3001
# Public hostname of staging FE (Vercel preview / Netlify branch URL)
FRONTEND_URL=https://staging-app.frequency.in
# Public hostname of THIS server. Used by every connector OAuth callback.
PUBLIC_API_URL=https://staging-api.frequency.in
# Staging is typically behind ONE CDN/load-balancer (Vercel / Cloudflare /
# Fly proxy). 0 if direct.
TRUST_PROXY_HOPS=1

# ── Supabase (staging project — separate from prod!) ──────────────────────
# Use a dedicated `frequency-staging` Supabase project, NOT prod.
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<from Supabase staging project Settings → API>
SUPABASE_ACCESS_TOKEN=<your personal access token>

# ── BLOCKERS — every secret below is independently HMAC-keyed ──────────────
# Generate FRESH for staging — do NOT reuse production keys.
# openssl rand -hex 32
IMPERSONATION_HMAC_SECRET=<generate-fresh-32-byte-hex>
OAUTH_STATE_SECRET=<generate-fresh-32-byte-hex>
ENCRYPTION_KEY=<generate-fresh-32-byte-hex>
ALLOW_SMOKE_TEST=0

# ── AI ─────────────────────────────────────────────────────────────────────
# Use a separate Anthropic API key for staging so usage shows up in its
# own billing line — easier to spot a runaway loop in dev/QA.
ANTHROPIC_API_KEY=<staging Anthropic key>
LOG_AI_USAGE=1

# ── Meta (WhatsApp + Instagram) ────────────────────────────────────────────
# Best practice: register a SEPARATE Meta App for staging with its own
# WABA + IG sandbox business. This isolates webhook traffic and avoids
# polluting production message logs.
META_APP_ID=<staging Meta App id>
META_APP_SECRET=<staging Meta App secret>
WH_VERIFY_TOKEN=<generate-fresh-32-byte-hex>
META_VERIFY_TOKEN=<generate-fresh-32-byte-hex>
META_REDIRECT_URI=https://staging-api.frequency.in/api/auth/instagram/callback

# ── Google (Sheets / Calendar / Drive / Gmail) ─────────────────────────────
# Add the staging callback URL as an Authorized Redirect URI in the
# Google Cloud Console OAuth client.
GOOGLE_CLIENT_ID=<staging Google OAuth client id>
GOOGLE_CLIENT_SECRET=<staging Google OAuth client secret>
GOOGLE_REDIRECT_URI=https://staging-api.frequency.in/api/auth/google/callback
# Legacy AES-CBC key (rewrap migration uses it during cutover; remove
# after src/scripts/rewrap-tokens.ts has been run + verified).
GOOGLE_TOKEN_SECRET=<32-char hex>

# ── Razorpay ───────────────────────────────────────────────────────────────
# Use rzp_test_* keys in staging. Webhook secret = staging webhook config.
RAZORPAY_KEY_ID=rzp_test_<staging>
RAZORPAY_KEY_SECRET=<staging test secret>
RAZORPAY_WEBHOOK_SECRET=<staging webhook secret>

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Use a separate Resend API key + sender so staging emails don't burn
# production sender reputation. Sender domain typically `staging-mail.frequency.in`.
RESEND_API_KEY=<staging Resend key>
RESEND_FROM_EMAIL=Frequency Staging <staging@frequency.in>
RESEND_REPLY_TO=

# ── WhatsApp notification template ────────────────────────────────────────
WA_NOTIFICATION_TEMPLATE_NAME=frequency_notification
WA_NOTIFICATION_TEMPLATE_LANG=en

# ── Connectors ─────────────────────────────────────────────────────────────
AIRTABLE_CLIENT_ID=<staging Airtable client id>
AIRTABLE_REDIRECT_URI=https://staging-api.frequency.in/api/auth/airtable/callback
SHOPIFY_API_KEY=<staging Shopify key>
SHOPIFY_API_SECRET=<staging Shopify secret>
SHOPIFY_REDIRECT_URI=https://staging-api.frequency.in/api/auth/shopify/callback
SHOPIFY_API_VERSION=2024-01

# ── Redis (BullMQ) ─────────────────────────────────────────────────────────
# Upstash free tier is fine for staging — pick the region closest to your
# server (ap-south-1 / Mumbai for India).
REDIS_URL=rediss://default:<password>@<region>.upstash.io:6379
WORKFLOW_CONCURRENCY=5
MESSAGE_CONCURRENCY=3
BROADCAST_CONCURRENCY=2
SCHEDULE_POLL_MS=30000
TEMPLATE_SYNC_INTERVAL_MS=900000
GMAIL_POLL_INTERVAL_MS=120000
TRIAL_ENDING_INTERVAL_MS=21600000
# If running web + worker as TWO services, set DISABLE_WORKERS=1 in the
# web service so they don't both poll queues. Set to 0 (or leave unset)
# in the worker service.
DISABLE_WORKERS=0

# ── F4: Idempotency cache cleanup ─────────────────────────────────────────
IDEMPOTENCY_RETENTION_HOURS=24
