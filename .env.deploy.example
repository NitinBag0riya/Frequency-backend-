# ═══════════════════════════════════════════════════════════════════════════
# Frequency — production deployment secrets template.
#
# DO NOT FILL IN THIS FILE. Copy to `.env.deploy` (gitignored), then edit:
#   cp .env.deploy.example .env.deploy
#
# `bin/deploy.sh` reads `.env.deploy` to populate Fly.io + Vercel secrets in
# one shot. The cryptographic secrets at the top should be generated FRESH
# for each environment via `openssl rand -hex 32`.
#
# NEVER commit `.env.deploy` — it contains live API keys + secrets that
# can buy AI inference / send WhatsApp messages on your dime.
# ═══════════════════════════════════════════════════════════════════════════

# ── Cryptographic secrets — generate with `openssl rand -hex 32` ──────────
# Save these somewhere safe (1Password / Bitwarden). Losing them means
# every stored OAuth token + impersonation session becomes unreadable.
IMPERSONATION_HMAC_SECRET=<openssl rand -hex 32>
OAUTH_STATE_SECRET=<openssl rand -hex 32>
ENCRYPTION_KEY=<openssl rand -hex 32>
WH_VERIFY_TOKEN=<openssl rand -hex 32>
META_VERIFY_TOKEN=<openssl rand -hex 32>
GOOGLE_TOKEN_SECRET=<openssl rand -hex 16>

# ── Fly.io app config ──────────────────────────────────────────────────────
FLY_APP_NAME=frequency-api-prod
FLY_REGION=bom

# ── Vercel project config ──────────────────────────────────────────────────
VERCEL_PROJECT_NAME=frequency-app

# ── REQUIRED — third-party API keys ────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=

ANTHROPIC_API_KEY=

META_APP_ID=
META_APP_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=Frequency <hello@frequency.in>

REDIS_URL=

# ── OPTIONAL connectors ────────────────────────────────────────────────────
AIRTABLE_CLIENT_ID=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
